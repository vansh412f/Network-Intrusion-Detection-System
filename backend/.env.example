# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/nids?retryWrites=true&w=majority

# Server port
PORT=3000

# Sensor authentication secret (must match sensor .env)
SENSOR_SECRET=change_this_to_a_secure_key

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Environment (development or production)
NODE_ENV=development