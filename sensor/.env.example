# Backend connection (in Docker: http://backend:3000, local: http://localhost:3000)
BACKEND_URL=http://localhost:3000

# Sensor authentication secret (must match backend SENSOR_SECRET)
SENSOR_SECRET=change_this_to_a_secure_key

# Network interface name (Windows: run `ipconfig /all`, Linux: run `ip link show`)
INTERFACE=Your-Network-Adapter-Name-Here

# Your local machine IP address (Windows: run `ipconfig`, Linux: run `ip addr`)
MY_IP=192.168.x.x